# Copy this file to .env.local (dev) or set these in your host's env (prod).
# .env.local is gitignored — never commit real secrets.

# --- Admin console ------------------------------------------------------------
# Password for the /admin login gate. Verified server-side only.
ADMIN_PASSWORD=change-me-before-deploying

# Secret stored in the admin session cookie and checked by admin API routes.
# Use a long random string in production, e.g. `openssl rand -hex 32`.
ADMIN_KEY=change-me-to-a-long-random-string

# --- Storefront (optional) ----------------------------------------------------
# WhatsApp click-to-chat number (digits only, incl. country code).
# NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# --- Data storage (optional) ---------------------------------------------------
# Where the JSON data store reads/writes. Leave unset for local dev (uses ./data).
# On Render, set this to your mounted disk path (see render.yaml) so bookings,
# orders, products etc. survive restarts and redeploys.
# DATA_DIR=/var/data
